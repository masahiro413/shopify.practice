<h1>{{ page.title }}</h1>
<div>
    {{ page.content }}
</div>

{% form 'contact'%}
    {{ form.errors | default_errors }}

    <div class="first-name">
        <label for="contact_first_name">First Name</label>
        <input type="text" id="contact_first_name" name="contact[first_name]" required>
    </div>

    <div class="email">
        <label for="contact_email">Email</label>
        <input type="email" id="contact{test}" name="contact[email]" required>
    </div>

    <div class="order-number">
        <label for="contact_order_number">Order Number</label>
        <input type="text" id="contact_order_number" name="contact[order_number]" required>
    </div>

    <div class="phone">
        <label for="contact_phone">Phone number</label>
        <input type="text" id="contact_phone" name="contact[phone]" required>
    </div>


    <div class="message">
        <label for="message">Message</label>
        <textarea id="contact_message" name="contact[body]" required></textarea>
    </div>

    <div class="submit">
        <label for="submit">Submit</label>
        <input type="submit" id="submit" name="submit" value="Send">
    </div>


  <input type="text" id="contact_name" name="contact[name]" required>

  <label for="contact_email">test</label>
  <input type="email" id="contact_email" name="contact[email]" required>

  <label for="contact_message">Message</label>
  <textarea id="contact_message" name="contact[body]" required></textarea>

  <button type="submit">Send</button>
{% endform %}
