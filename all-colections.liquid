<section class="all-collections">
    <h1>Featured Collections</h1>
<div class="collection-container">
    <div class="collection-wrrapper">
{% for collection in collections %}
    <h3>{{ collection.title|link_to: collection.url }}</h3>
{%endfor%}
</div>
</div>
</section>

{% schema %}
{
  "name": "All Collections",
  "settings": [
  {
  "type": "color",
  "id": "background",
  "label": "Background",
  "default": "#ffffff"
  },
  {
  "type": "color",
  "id": "text_color",
  "label": "Text Color",
  "default": "#000000"
  }
  ],
  "presets": [
    {
      "name": "Banner"
    },
  ]
}
{% endschema %}
