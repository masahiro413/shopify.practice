{% paginate blog.articles by 4 %}

       <h1>{{ blog.title }}</h1>

       {% for article in blog.articles %}
           <div>
              <a href="{{ article.url }}">
                 <h2>{{ article.title }}</h2>
                 <p>products:{{ article.author | strip_html | truncate: 150 }}</p>
                 <div>{{ article.excerpt | strip_html | truncate: 300 }}</div>
              </a>
            </div>
       {% endfor %}

   {{ paginate | default_pagination }}
{% endpaginate %}
