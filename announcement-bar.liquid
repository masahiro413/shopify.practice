{% if section.settings['show-announcement'] %}
  <section>
    <div class="announcement-bar">
      <div class="announcement-bar-left-section">
        {% if section.settings.image != blank %}
          <img
            width="40"
            height="40"
            loading="lazy"
            src="{{ section.settings.image | image_url }}"
          />
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'announcement-bar-fallback-icon' }}
        {% endif %}
      </div>
      <div class="announcement-bar-right-section">

        <ul class="announcement-bar-inner-list">

          {% if section.blocks.size == 0 %}
            <li>
              <a href="#">help</a>
            </li>
            {%  if shop.customer_accounts_enabled %}
            {%  if customer %}
            <li>
              <a href="{{ routes.account_url }}">Account</a>
            </li>

          {%  else %}
            <li>
              <a href="{{ routes.account_login_url }}">Sign In</a>
            </li>

           {%  endif %}
          {%  endif %}

          {% else %}
              {% for block in section.blocks %}
                <li>
                  <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
                </li>
              {% endfor %}
          {% endif %}
        </ul>
      </div>
    </div>
  </section>
{% endif %}

<style>
  .announcement-bar {
     background:{{ section.settings.background }};
     ;
     color:{{ section.settings.text_color }}
     ;
     display:flex;
     justify-content:space-between;
     padding:0,30px,50px
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show-announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Pink Image"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "links",
      "name": "Links",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
