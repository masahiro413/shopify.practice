.__pf img,.__pf svg {
  max-width: 100%;
  height: auto;
  border:0;
  display: block;
}.__pf :focus-visible{outline: 0!important;box-shadow: 0 0 0 2px var(--pf-color-focus-ring, #5c6ac4)}.__pf :focus:not(:focus-visible){outline: none!important;box-shadow: none!important
}

body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: var(--page-bg, #ffffff);
    color: var(--page-text, #111111);
}

.header {
    padding: 24px;
    background: #ffffff;
    border-bottom: 1px solid #e5e7eb;
}

.header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
}

.site-title {
    margin: 0;
    font-size: 24px;
}

.drawer-icon {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    text-decoration: none;
    margin-left: auto;
}

.drawer-icon span {
    display: block;
    width: 24px;
    height: 2px;
    background: #5a9bdd;
    transition: transform 0.2s ease, opacity 0.2s ease;
}

.drawer-icon.is-checked span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
}

.drawer-icon.is-checked span:nth-child(2) {
    opacity: 0;
}

.drawer-icon.is-checked span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
}

.navigation {
    display: none;
    position: absolute;
    top: 80px;
    right: 16px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 12px 16px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
}

.navigation.is-checked {
    display: block;
}

.navigation ul {
    margin: 0;
    padding: 0;
    list-style: none;
}

.navigation li + li {
    margin-top: 8px;
}

.navigation a {
    color: #66aff7;
    text-decoration: none;
}

.navigation a:hover {
    text-decoration: underline;
}

@media (min-width: 768px) {
    .drawer-icon {
        display: none;
    }

    .navigation {
        position: static;
        display: block;
        border: none;
        box-shadow: none;
        padding: 0;
    }

    .navigation ul {
        display: flex;
        gap: 16px;
    }

    .navigation li + li {
        margin-top: 0;
    }
}

#MainContent {
    padding: 32px 24px;
}
.product {
    display: flex;
    gap: 32px;
}
.product-image {
    width: 400px;
    height: 400px;
    background-size: cover;
    background-position: center;
}
.product-info {
    max-width: 400px;
}

.product-title {
    font-size: 24px;
    margin-bottom: 16px;
}
.product-description {
    font-size: 16px;
    margin-bottom: 16px;
}
.product-price {
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 16px;
}
.product-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
}
.product-form select {
    padding: 8px;
    font-size: 16px;
}

.product-form button {
    padding: 12px;
    font-size: 16px;
    background: #77b1ec;
    color: #ffffff;
    border: none;
    cursor: pointer;
}
.product-form button:hover {
    background: #51e275;
}

.product-form .ensiform {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.product-form .ensiform label {
    font-size: 14px;
}

.product-form .ensiform select {
    padding: 8px;
    font-size: 16px;
}

.product-form .ensiform button {
    padding: 12px;
    font-size: 16px;
    background: #4ae5d5;
    color: #ffffff;
    border: none;
    cursor: pointer;
}
.product-form .ensiform button:hover {
    background: #11181c;
}
