{%  form 'cart' cart%}

   <h1>Shopping Cart</h1>
   
   {% if cart.empty %}
      <p>Your cart is empty?</p>
    {% else %}
   {% for item in cart.items %}


     <div>
        <img src="{{ item.image | image_url: width: 200 }}" width="200" height="200" alt="{{ item.product.title }}"/>
        <h2>{{ item.product.title }}</h2>
        <p>{{ item.line_price | money }}</p>
        input name="updates[]" type="number" value="{{ item.quantity }}" min="0" />
        <a href="{{ item.url_to_remove }}">Remove</a>
  </div>
   {% endfor %}

   <hr/>
    <p>Total: {{ cart.total_price | money }}</p>

   <button type="submit" name="update">
      Update Cart
   </button>

   <button type="submit" name="checkout">
      Checkout
   </button>
   
   {% endif %}

{% endform %}
